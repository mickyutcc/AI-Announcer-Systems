        {
          "expr": "rate(tts_cache_misses_total[5m])",
          "legendFormat": "cache_misses"
        }
      ],
      "title": "Cache Hits/Misses Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "usd"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 6,
      "targets": [
        {
          "expr": "increase(tts_cost_estimated_total[30d])",
          "legendFormat": "cost_30d"
        }
      ],
      "title": "Estimated Cost (30d)",
      "type": "timeseries"
    }
